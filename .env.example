# LLM API 配置
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_API_URL=https://api.openai.com/v1
LLM_TIMEOUT=300.0

# 多 Base URL 配置（可选，设置后覆盖 OPENROUTER_API_URL）
# 格式1 - JSON 数组（每个 URL 可指定不同的 api_key）:
# LLM_BASE_URLS=[{"url":"https://api1.openai.com/v1","api_key":"sk-..."},{"url":"https://api2.openai.com/v1","api_key":"sk-..."}]
# 格式2 - 逗号分隔的 URL 列表（共用 OPENROUTER_API_KEY）:
# LLM_BASE_URLS=https://api1.openai.com/v1,https://api2.openai.com/v1

# 可用模型列表（逗号分隔）
AVAILABLE_MODELS=gpt-4o,gpt-4o-mini,claude-3.5-sonnet,gpt-5.1

# 数据库配置
DATABASE_URL=sqlite:///./debate_arena.db

# Bing Search API（用于搜索工具，替代旧版 Google Serper）
BING_API_KEY=your_bing_api_key_here

# Serper API（已废弃，保留向后兼容）
# SERPER_API_KEY=your_serper_api_key_here
