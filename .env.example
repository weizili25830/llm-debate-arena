# LLM API 配置
# 使用 DashScope (Alibaba Cloud) 兼容 OpenAI 模式
OPENROUTER_API_KEY=sk-your_dashscope_api_key_here
OPENROUTER_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=300.0

# 多 Base URL 配置（可选，设置后覆盖 OPENROUTER_API_URL）
# DashScope 三个区域（华北2北京、新加坡、美国弗吉尼亚）依次尝试:
# LLM_BASE_URLS=[{"url":"https://dashscope.aliyuncs.com/compatible-mode/v1","api_key":"sk-..."},{"url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1","api_key":"sk-..."},{"url":"https://dashscope-us.aliyuncs.com/compatible-mode/v1","api_key":"sk-..."}]
# 格式2 - 逗号分隔的 URL 列表（共用 OPENROUTER_API_KEY）:
# LLM_BASE_URLS=https://dashscope.aliyuncs.com/compatible-mode/v1,https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# 可用模型列表（逗号分隔）
AVAILABLE_MODELS=qwen3.5-plus

# 数据库配置
DATABASE_URL=sqlite:///./debate_arena.db
